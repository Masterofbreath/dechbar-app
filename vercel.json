{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "dechbar.cz" }],
      "destination": "https://www.dechbar.cz/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
